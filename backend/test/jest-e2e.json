{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!uuid/)"
  ],
  "moduleNameMapper": {
    "^core/(.*)$": "<rootDir>/../src/core/$1",
    "^(\\.\\.?/.+)\\.js$": "$1"
  }
}
